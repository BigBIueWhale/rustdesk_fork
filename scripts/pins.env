# scripts/pins.env — the single source of truth for every version the build fixes.
#
# Machine-readable form of requirements.html §3.2 (R-B5a, R-B10, R-R1). A
# shell-sourceable KEY=value manifest: no build script may resolve "latest" or a
# moving channel — every version comes from here (R-B9). Each value below is read
# from the pinned tree (rustdesk 0c86d46 / hbb_common df6badc) at its cited
# location and re-verified against the repo.
#
# Two kinds of pin live here:
#   1. VERSIONS / git SHA-1 commit pins — fully fixed below (verified in-tree).
#   2. SHA-256 artifact digests for ./online (R-B10) — every fetched toolchain,
#      SDK, image and installer. These are deliberately set to the sentinel
#      __PENDING_R_B12__ rather than fabricated: R-B12 requires each first pin be
#      established by an AUDITED, DUAL-SOURCED bootstrap (publisher hash/signature
#      cross-checked against a second path) and recorded with provenance. That
#      bootstrap needs the real artifacts over the network; it cannot be done
#      offline, and a fabricated digest would be worse than an honest gap.
#      online-fetch.sh (R-B10) MUST treat the sentinel as a hard, fail-closed
#      error — never fetch-and-trust.
SHA_PENDING="__PENDING_R_B12__"

# ── Source pins (git SHA-1; the only content anchor for git deps, R-B12) ──────
RUSTDESK_COMMIT="0c86d4616298f09435f6236599b300964aa61460"   # tag 1.4.7
HBB_COMMON_COMMIT="df6badca5bf81b4e9836256cf8e31c993ad70dd1" # absorbed in-tree (libs/hbb_common)
VCPKG_BASELINE="120deac3062162151622ca4860575a33844ba10b"    # vcpkg.json default-registry baseline (registry snapshot 2025.08.27)
ADVISORY_DB_COMMIT="4ea955aed4d1b1214badc01f9d029bb12ef9e8e4" # RustSec advisory-db snapshot 2025-11-30 (R-R3 audit, scripts/Dockerfile.audit); pre-2026 schema so cargo-audit 0.21.1 can parse it. Bump deliberately + re-review deny.toml.

# ── Toolchain (R-B5a, §3.2) ───────────────────────────────────────────────────
RUST_VERSION="1.75"          # all shipped targets; rust-toolchain.toml + flutter-build.yml RUST_VERSION (edition 2021)
RUST_VERSION_MACOS="1.81"    # macOS-only, NOT a build target (R-R2); recorded for the Apple cargo-check job
FLUTTER_VERSION="3.24.5"     # FLUTTER_VERSION / ANDROID_FLUTTER_VERSION
LLVM_VERSION="15.0.6"        # LLVM_VERSION (bindgen libclang determinism, R-B12)
PYTHON_VERSION="3.11.9"      # PYTHON_VERSION (build.py orchestrator + libs/portable/generate.py brotli, §12.2 win)
ANDROID_NDK_VERSION="r28c"   # NDK_VERSION (SDK pkg ndk;28.2.13676358)
CARGO_NDK_VERSION="3.1.2"    # CARGO_NDK_VERSION (MSRV 1.68 — builds on 1.75)
CARGO_AUDIT_VERSION="0.21.1" # last cargo-audit supporting rustc 1.75 (0.22+ needs 1.88); scripts/Dockerfile.audit, R-R3/R-A7

# ── Flutter / Android build host (§3.2) ───────────────────────────────────────
ANDROID_AGP_VERSION="7.3.1"          # flutter/android/settings.gradle (com.android.application)
ANDROID_KOTLIN_VERSION="2.1.21"      # flutter/android/settings.gradle (kotlin.android)
ANDROID_GRADLE_WRAPPER="7.6.4"       # flutter/android/gradle/wrapper/gradle-wrapper.properties
ANDROID_JDK_VERSION="17"             # CI JAVA_HOME (android job)
ANDROID_COMPILE_SDK="34"             # flutter/android/app/build.gradle compileSdkVersion
ANDROID_BUILD_TOOLS="34.0.0"         # build-tools (§3.2)
ANDROID_TARGET_SDK="33"              # targetSdkVersion
ANDROID_MIN_SDK="22"                 # minSdkVersion
ANDROID_NDK_API="21"                 # flutter/ndk_arm64.sh
ANDROID_CMDLINE_TOOLS_BUILD="15641748" # cmdline-tools;latest rev 21 versioned build number (the reproducible pin; NOT the moving "...-latest.zip"); from the Android SDK repository2-1.xml

# ── Code generation (R-B7, R-B12) ─────────────────────────────────────────────
FLUTTER_RUST_BRIDGE_VERSION="1.80.1" # bridge.yml; built with --features "uuid" --locked → generated_bridge.dart / bridge_generated.rs

# ── Native deps via vcpkg overrides (§3.2; overlay ports in ./res/vcpkg) ───────
# R-R2b: the hardware-codec natives (ffmpeg + mfx-dispatch) and their hwaccel
# override pins (ffnvcodec, amd-amf) are PRUNED from vcpkg.json (CPU-only software
# codec, Appendix C #2b); they were also the multi-hour build that made the §12.2
# Windows VM build infeasible. scripts/verify.sh gates their absence.
# Overlay ports (patched, in res/vcpkg): aom libvpx libyuv opus
# Native set built from baseline: aom libvpx libyuv opus libjpeg-turbo oboe
#   cpu-features. Crypto is the sodiumoxide crate, NOT vcpkg.

# ── Windows packaging (§3.2) ──────────────────────────────────────────────────
WIX_TOOLSET_VERSION="4"              # WixToolset.WcaUtil/DUtil 4.0.5; res/msi targets schemas/v4

# ── Per-target build config (exact, from build.py get_features) ────────────────
# Debian x86_64 : triple x86_64-unknown-linux-gnu  | triplet x64-linux           | features hwcodec,flutter,unix-file-copy-paste
# Android aarch64: triple aarch64-linux-android     | triplet arm64-android       | features flutter,hwcodec
# Windows x86_64 : triple x86_64-pc-windows-msvc    | triplet x64-windows-static  | features hwcodec,vram,flutter
# Controlled-only profile (R-R2b): viewer OFF; decode/hwcodec/vram/flutter OFF (CPU-only encode).

# ── SHA-256 digests for ./online artifacts (R-B10/R-B12) — all PENDING ─────────
# Filled only by the audited dual-source bootstrap (R-B12). online-fetch.sh
# aborts fail-closed on any "$SHA_PENDING" value. Names are fixed now so a future
# image/toolchain drift is caught the moment a real digest is recorded.
SHA256_RUST_1_75="6bf166ddcad545aa26aa2d12a186454d7697133b52b7fbbd271ce3ee1ecfedc6" # rust-1.75.0-x86_64-unknown-linux-gnu.tar.xz | R-B12 (2026-06-22): GPG "Good signature" on channel-rust-1.75.0.toml by the Rust release key 108F6620 5EAEB0AA A8DD5E1C 85AB96E6 FA1BE5FE; its xz_hash equals the standalone .tar.xz.sha256 (signed-manifest + integrity-file = two paths)
SHA256_RUST_STD_ANDROID_1_75="6225fa73cf98fc11e83e14b7021391678fcb4a71b7c2b7db05a0793240ea2945" # rust-std-1.75.0-aarch64-linux-android.tar.xz (dist/2023-12-28) | R-B12 (2026-06-23): the aarch64-linux-android std component for the cargo-ndk JNI cross-compile (the host rust tarball ships only x86_64-unknown-linux-gnu). GPG "Good signature" on channel-rust-1.75.0.toml by the same Rust release key 108F6620 5EAEB0AA A8DD5E1C 85AB96E6 FA1BE5FE; the manifest's [pkg.rust-std.target.aarch64-linux-android] xz_hash equals the standalone .tar.xz.sha256 (signed-manifest + integrity-file = two paths)
SHA256_FLUTTER_3_24_5="a7c82f551a9eae018e078f6bb186171e5a77920d35a3d75a61d9a593d0a9e4ae" # flutter_linux_3.24.5-stable.tar.xz | R-B12 (2026-06-22): Google releases_linux.json manifest sha256 == independent download-and-compute (publisher manifest + byte-integrity verification, two paths)
SHA256_FLUTTER_WIN_3_24_5="b8a7485acd3c6fb23a76b7ac09f89e8d93d62fbff7147c6f5f8c5686d949eeac" # flutter_windows_3.24.5-stable.zip | R-B12 (2026-06-23): Google releases_windows.json manifest sha256 == independent download-and-compute (publisher manifest + byte-integrity verification, two paths) — the WINDOWS flutter SDK for the §12.2 VM build (the .tar.xz pin above is linux-only); both share FLUTTER_VERSION
SHA256_FLUTTER_WIN_ENGINE="413c7117cc60545629367f73545aa5b3720687eddc77d7d48f93477e4f05440e" # online/flutter-windows-engine.tar.gz | R-B12 (2026-06-23): the windows flutter ENGINE (artifacts/engine/windows-x64{,-profile,-release}) + the 3 stamps precache writes (windows-sdk.stamp/libimobiledevice.stamp/usbmuxd.stamp), staged OFFLINE by online-fetch stage_windows_engine (the in-VM precache 780MB CDN fetch stalls over slirp). windows-sdk.stamp is LOAD-BEARING: without it the windows flutter re-downloads despite the artifacts being present. DETERMINISTIC (sorted tar + gzip -n over the version-pinned engine+stamp content); shipped on the TOOLCHAINS CD + pre-placed by win-guest-setup
SHA256_FLUTTER_PUB_CACHE="2e17bac34a6a3229c91f4786f78d23ff10dbee1c49b2053b84838202d99d805c" # online/flutter-pub-cache.tar.gz | R-B12 (2026-06-23): the flutter_tools 3.24.5 hosted pub cache (hosted/pub.dev/* + hosted-hashes/pub.dev/*; 95 pinned packages incl. the DEV deps test-1.25.7/test_core/test_api/fake_async — the flutter SDK zip's BUNDLED cache ships only flutter_tools' RUNTIME deps, so `dart pub get --offline` over the bundled cache alone FAILS "version solving failed"). Staged OFFLINE by online-fetch stage_flutter_pub_cache (the in-VM first-run flutter_tools resolve makes ~98 pub.dev metadata round-trips that stall over slirp). Pre-placed by win-guest-setup at %LOCALAPPDATA%\Pub\Cache BEFORE the offline resolve. DETERMINISTIC (sorted tar + gzip -n over the version-pinned, pubspec.lock-fixed package set). Docker-verified: a FRESH flutter 3.24.5 with PUB_CACHE = ONLY this extracted cache resolves flutter_tools offline ("Got dependencies", exit 0, zero pub.dev traffic)
SHA256_LLVM_15_0_6="38bc7f5563642e73e69ac5626724e206d6d539fbef653541b34cae0ba9c3f036" # clang+llvm-15.0.6-x86_64-linux-gnu-ubuntu-18.04.tar.xz | R-B12 (2026-06-22): download-computed from the official github llvm-project release llvmorg-15.0.6 (TLS); independently confirmed by grailbio/bazel-toolchain@0.8.2 llvm_distributions.bzl, which records the identical SHA-256 (two paths)
SHA256_LLVM_WIN_15_0_6="22e2f2c38be4c44db7a1e9da5e67de2a453c5b4be9cf91e139592a63877ac0a2" # LLVM-15.0.6-win64.exe | R-B12 (2026-06-23): the WINDOWS clang/libclang installer for the §12.2 VM build (FRB/bindgen libclang determinism; the linux pin above is linux-only). Microsoft winget-pkgs LLVM.LLVM/15.0.6 x64 InstallerSha256 == independent github download-and-compute of LLVM-15.0.6-win64.exe (winget manifest + byte-integrity, two paths)
SHA256_PYTHON_WIN_3_11_9="5ee42c4eee1e6b4464bb23722f90b45303f79442df63083f05322f1785f5fdde" # python-3.11.9-amd64.exe | R-B12 (2026-06-23): the WINDOWS Python for the §12.2 build host (build.py + libs/portable/generate.py); download-computed from the official python.org FTP release (TLS)
SHA256_ANDROID_NDK_R28C="dfb20d396df28ca02a8c708314b814a4d961dc9074f9a161932746f815aa552f" # android-ndk-r28c-linux.zip | R-B12 (2026-06-22): download-computed SHA-256; the same download's SHA-1 (a7b54a5de87fecd125a17d54f73c446199e72a64) matches the official Android NDK wiki (github.com/android/ndk/wiki/Unsupported-Downloads) — official-wiki SHA-1 + download-computed SHA-256, two paths
SHA256_ANDROID_CMDLINE_TOOLS="a66d5ef0238fc0162e9c1446602ce0dd41702d4dd7a94d2ce42d12b7f80baf7e" # commandlinetools-linux-15641748_latest.zip (rev 21) | R-B12 (2026-06-22): download-computed SHA-256; the same download's SHA-1 (63523a02a975a81102238566f2a16c057d52301e) matches the Android SDK repository2-1.xml checksum for the linux cmdline-tools;latest archive (SDK-XML SHA-1 + download-compute, two paths)
SHA256_VCPKG_120DEAC3="f3b1ec711fa1ba291efd75e27983898a37be15760dfe129a406448fa7377b31d" # vcpkg archive @ baseline commit 120deac3 | R-B12 (2026-06-22): SHA-256 of the official GitHub archive (microsoft/vcpkg @ the pinned VCPKG_BASELINE commit = the git content anchor), download-computed. CAVEAT: GitHub archive tarballs are NOT guaranteed byte-stable across GitHub recompression; the commit SHA-1 is the true anchor — re-pin from the fixed commit if a future fetch fail-closes (or switch online-fetch to git-clone+checkout).
SHA256_FRB_1_80_1="5c1494e79024de228a9f383c8e52e45b042cd0cf24f4b0f47ee4d5448938b336" # flutter_rust_bridge v1.80.1 source archive | R-B12 (2026-06-22): SHA-256 of the official GitHub archive (fzyzcjy/flutter_rust_bridge @ tag v1.80.1), download-computed. Same GitHub-archive byte-stability caveat as vcpkg — the tag/commit is the content anchor.
SHA256_BASEIMAGE_UBUNTU_1804="sha256:152dc042452c496007f07ca9127571cb9c29697f42acbfad72324b2bb2e43c98" # digest-pinned .deb build image (Docker Hub official library/ubuntu:18.04 manifest-list digest; content-addressed — `docker pull` verifies content==digest; R-B12 2026-06-22)
SHA256_BASEIMAGE_UBUNTU_2404="sha256:786a8b558f7be160c6c8c4a54f9a57274f3b4fb1491cf65146521ae77ff1dc54" # digest-pinned .apk build image (Docker Hub official library/ubuntu:24.04 manifest-list digest; content-addressed; R-B12 2026-06-22)
SHA256_WIN11_ISO="0df2f173d84d00743dc08ed824fbd174d972929bd84b87fe384ed950f5bdab22" # Win11 22H2 x64 (operator-captured ISO on the cte build host, R-B12(c) evergreen)
SHA256_VS_BUILDTOOLS="a3bee3c56f31919aa1510701ee62329ce4b7c610e577203ffd5bad0603b57f43" # captured VS BuildTools VCTools offline layout (vs_buildtools --layout, x64) → online/vs-buildtools.layout.tar; evergreen, R-B12(c)
SHA256_WIX4="$SHA_PENDING"
